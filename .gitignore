# =========================
# Peta Jati Diri - Git Ignore
# Goal: commit source/config only, never heavy generated output
# =========================

# Dependencies
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks

# Build output / generated app artifacts
dist/
dist-ssr/
build/
.output/
.vinxi/
.tanstack/
.nitro/
.cache/
coverage/

# Local environment / secrets
.env
.env.*
!.env.example
*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS files
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Cloudflare / Wrangler local artifacts
.wrangler/
.dev.vars

# Lovable generated workspace notes; not needed for production source repo
.lovable/

# Raw study notes already converted into src/data/*.ts
human_energy_map_project_blueprint.md
human_pattern_question_bank_v_1.md

# Package manager lock not used by this npm-based project
# Keep package-lock.json if you generate one with npm install.
bun.lock

# Temporary exports and archives
*.zip
exports/
screenshots/
